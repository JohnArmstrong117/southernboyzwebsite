---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MapEmbed from '../components/MapEmbed.astro';
import business from '../data/business.json';

const pageTitle = `Contact | ${business.name}`;
const pageDescription = `Get in touch with ${business.name}. Call ${business.phone} or visit us at ${business.address.street}, ${business.address.city}.`;
const fullAddress = `${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />
  <main>
    <!-- Page hero -->
    <section class="bg-gray-50 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl">Contact Us</h1>
        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-gray-600">
          Have a question or ready to schedule a service? We'd love to hear from you.
          Reach out by phone, email, or the form below.
        </p>
      </div>
    </section>

    <section class="py-16 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2">
          <!-- Contact info -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Get in Touch</h2>
            <ul class="mt-8 space-y-6">
              <li class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Phone</p>
                  <a href={`tel:${business.phone.replace(/\D/g, '')}`} class="text-brand-600 hover:text-brand-700">
                    {business.phone}
                  </a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Email</p>
                  <a href={`mailto:${business.email}`} class="text-brand-600 hover:text-brand-700">
                    {business.email}
                  </a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Address</p>
                  <p class="text-gray-600">{fullAddress}</p>
                </div>
              </li>
            </ul>

            <div class="mt-10">
              <h3 class="font-semibold text-gray-900">Business Hours</h3>
              <ul class="mt-4 space-y-2 text-sm text-gray-600">
                {
                  business.hours.map((item) => (
                    <li class="flex justify-between gap-4 border-b border-gray-100 pb-2">
                      <span class="font-medium text-gray-800">{item.days}</span>
                      <span>{item.hours}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <!-- Contact form (static — no backend) -->
          <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm sm:p-8">
            <h2 class="text-xl font-bold text-gray-900">Send a Message</h2>
            <p class="mt-2 text-sm text-gray-600">
              Fill out the form below and we'll get back to you within one business day.
            </p>
            <form class="mt-6 space-y-5" action="#" method="post">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
                  placeholder="you@example.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700">Phone <span class="text-gray-400">(optional)</span></label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
                  placeholder="(555) 555-5555"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
                  placeholder="Tell us about your project..."
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-700 sm:w-auto"
              >
                Send Message
              </button>
              <p class="text-xs text-gray-500">
                This is a static template. Connect the form to your email service or CRM to receive submissions.
              </p>
            </form>
          </div>
        </div>

        <!-- Map -->
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-gray-900">Find Us</h2>
          <div class="mt-6">
            <MapEmbed />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
