---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon = '🔧' } = Astro.props;
---

<article class="flex flex-col rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand-50 text-2xl" aria-hidden="true">
    {icon}
  </div>
  <h3 class="text-lg font-semibold text-gray-900">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600">{description}</p>
  <a
    href="/contact"
    class="mt-4 inline-flex items-center text-sm font-semibold text-brand-600 hover:text-brand-700"
  >
    Request a quote
    <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</article>
