---
import business from '../data/business.json';

const year = new Date().getFullYear();
const fullAddress = `${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`;
---

<footer class="mt-auto border-t border-gray-100 bg-gray-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <p class="text-lg font-bold text-brand-700">{business.name}</p>
        <p class="mt-2 text-sm text-gray-600">{business.tagline}</p>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900">Contact</h3>
        <ul class="mt-4 space-y-2 text-sm text-gray-600">
          <li>
            <a href={`tel:${business.phone.replace(/\D/g, '')}`} class="hover:text-brand-600">
              {business.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${business.email}`} class="hover:text-brand-600">
              {business.email}
            </a>
          </li>
          <li>{fullAddress}</li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900">Hours</h3>
        <ul class="mt-4 space-y-2 text-sm text-gray-600">
          {
            business.hours.map((item) => (
              <li>
                <span class="font-medium text-gray-800">{item.days}:</span> {item.hours}
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900">Quick Links</h3>
        <ul class="mt-4 space-y-2 text-sm text-gray-600">
          <li><a href="/about" class="hover:text-brand-600">About Us</a></li>
          <li><a href="/services" class="hover:text-brand-600">Services</a></li>
          <li><a href="/contact" class="hover:text-brand-600">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-gray-200 pt-8 sm:flex-row">
      <p class="text-sm text-gray-500">
        &copy; {year} {business.name}. All rights reserved.
      </p>
      <div class="flex gap-4">
        {
          business.social.facebook && (
            <a
              href={business.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-500 hover:text-brand-600"
            >
              Facebook
            </a>
          )
        }
        {
          business.social.instagram && (
            <a
              href={business.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-500 hover:text-brand-600"
            >
              Instagram
            </a>
          )
        }
        {
          business.social.google && (
            <a
              href={business.social.google}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-500 hover:text-brand-600"
            >
              Google
            </a>
          )
        }
      </div>
    </div>
  </div>
</footer>
